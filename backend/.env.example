# ─── AI Provider ────────────────────────────────────────────────────────────
# Opciones: "gemini" (default) | "openrouter"
AI_PROVIDER=gemini

# Modelo específico del proveedor
# Gemini:     gemini-1.5-flash | gemini-1.5-pro | gemini-2.0-flash
# OpenRouter: openai/gpt-4o-mini | anthropic/claude-3-haiku | meta-llama/llama-3-8b-instruct
AI_MODEL=gemini-2.0-flash

# ─── API Keys ────────────────────────────────────────────────────────────────
# Solo necesitas la del proveedor que vayas a usar

# Google Gemini → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenRouter → https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ─── Servidor externo mock ───────────────────────────────────────────────────
# URL base del servidor mock (solo en entorno local)
# En producción, apunta a tu sistema externo real
EXTERNAL_SERVER_URL=http://localhost:3010

# ─── Logging ─────────────────────────────────────────────────────────────────
# Niveles: debug | info | warn | error  (default: info)
# Usa "debug" para ver los mensajes usuario↔agente y las llamadas MCP
LOG_LEVEL=debug


# El correo especial generado por el Service Account 
GOOGLE_SERVICE_ACCOUNT_EMAIL="tu-servicio@tu-proyecto.iam.gserviceaccount.com"
