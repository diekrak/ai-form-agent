# El ID del Google Sheet. Lo encuentras en la URL de tu hoja de cálculo.
# Por ejemplo: https://docs.google.com/spreadsheets/d/AQUI-ESTA-EL-ID/edit
GOOGLE_SHEET_ID="tu-ID-de-sheet"

# El nombre de la hoja y la celda inicial (e.g., "Sheet1!A1" o "Hoja 1!A1")
GOOGLE_SHEET_RANGE="Sheet1!A1"